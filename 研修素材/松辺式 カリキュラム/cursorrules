## srcdocビューア編集パターン（Python）

```python
import re, html

with open("AIスクール2026_全スライド.html", encoding="utf-8") as f:
    source = f.read()

# スライドブロックを分割
blocks = re.split(r'(?=<div class="slide-wrap">)', source)

new_blocks = []
for block in blocks:
    m = re.search(r'srcdoc="(.*?)"(?=\s*loading)', block, re.DOTALL)
    if m:
        inner = html.unescape(m.group(1))
        # ここで inner に対して修正を加える
        # inner = inner.replace("変更前", "変更後")
        encoded = html.escape(inner, quote=True)
        block = block[:m.start(1)] + encoded + block[m.end(1):]
    new_blocks.append(block)

result = "".join(new_blocks)

with open("AIスクール2026_全スライド_修正版.html", "w", encoding="utf-8") as f:
    f.write(result)
```

